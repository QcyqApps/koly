generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String    @id @default(uuid())
  email               String    @unique
  passwordHash        String    @map("password_hash")
  name                String?
  businessName        String?   @map("business_name")
  industry            String?
  city                String?
  taxForm             String    @default("ryczalt") @map("tax_form")
  taxRate             Decimal   @default(8.5) @map("tax_rate") @db.Decimal(5, 2)
  zusMonthly          Decimal   @default(0) @map("zus_monthly") @db.Decimal(10, 2)
  monthlyGoal         Decimal?  @map("monthly_goal") @db.Decimal(10, 2)
  subscriptionStatus  String    @default("trial") @map("subscription_status")
  trialEndsAt         DateTime  @default(dbgenerated("NOW() + INTERVAL '14 days'")) @map("trial_ends_at")
  onboardingCompleted Boolean   @default(false) @map("onboarding_completed")
  isDemo              Boolean   @default(false) @map("is_demo")
  refreshToken        String?   @map("refresh_token")
  createdAt           DateTime  @default(now()) @map("created_at")

  fixedCosts        FixedCost[]
  serviceCategories ServiceCategory[]
  services          Service[]
  visits            Visit[]
  dailySnapshots    DailySnapshot[]
  chatMessages      ChatMessage[]
  aiReports         AiReport[]
  galleryImages     GalleryImage[]
  generatedCaptions GeneratedCaption[]

  @@map("users")
}

model FixedCost {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  name      String
  amount    Decimal  @db.Decimal(10, 2)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("fixed_costs")
}

model ServiceCategory {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  name      String
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  services Service[]

  @@index([userId])
  @@map("service_categories")
}

model Service {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  categoryId      String?  @map("category_id")
  name            String
  price           Decimal  @db.Decimal(10, 2)
  durationMinutes Int      @map("duration_minutes")
  materialCost    Decimal  @default(0) @map("material_cost") @db.Decimal(10, 2)
  isActive        Boolean  @default(true) @map("is_active")
  isFavorite      Boolean  @default(false) @map("is_favorite")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  category ServiceCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  visits   Visit[]

  @@index([userId])
  @@index([categoryId])
  @@map("services")
}

model Visit {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  serviceId   String   @map("service_id")
  visitDate   DateTime @map("visit_date") @db.Date
  status      String   @default("completed")
  actualPrice Decimal? @map("actual_price") @db.Decimal(10, 2)
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  service       Service        @relation(fields: [serviceId], references: [id])
  galleryImages GalleryImage[]

  @@index([userId, visitDate])
  @@index([userId, status])
  @@map("visits")
}

model DailySnapshot {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  snapshotDate    DateTime @map("snapshot_date") @db.Date
  revenue         Decimal  @default(0) @db.Decimal(10, 2)
  materialCosts   Decimal  @default(0) @map("material_costs") @db.Decimal(10, 2)
  fixedCostsDaily Decimal  @default(0) @map("fixed_costs_daily") @db.Decimal(10, 2)
  estimatedTax    Decimal  @default(0) @map("estimated_tax") @db.Decimal(10, 2)
  netProfit       Decimal  @default(0) @map("net_profit") @db.Decimal(10, 2)
  visitCount      Int      @default(0) @map("visit_count")
  noShowCount     Int      @default(0) @map("no_show_count")
  noShowCost      Decimal  @default(0) @map("no_show_cost") @db.Decimal(10, 2)
  servicesRanking Json?    @map("services_ranking")
  aiSuggestions   Json?    @map("ai_suggestions")
  aiSummary       String?  @map("ai_summary")
  createdAt       DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, snapshotDate])
  @@index([userId, snapshotDate(sort: Desc)])
  @@map("daily_snapshots")
}

model ChatMessage {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  sessionId String   @map("session_id")
  role      String
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, sessionId, createdAt])
  @@map("chat_messages")
}

model AiReport {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  reportType  String   @default("weekly") @map("report_type")
  periodStart DateTime @map("period_start") @db.Date
  periodEnd   DateTime @map("period_end") @db.Date
  content     String
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, periodStart])
  @@map("ai_reports")
}

model GalleryImage {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  visitId       String?  @map("visit_id")
  filename      String
  originalName  String   @map("original_name")
  mimeType      String   @map("mime_type")
  fileSize      Int      @map("file_size")
  thumbnailPath String?  @map("thumbnail_path")
  description   String?
  isPortfolio   Boolean  @default(true) @map("is_portfolio")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  visit    Visit?            @relation(fields: [visitId], references: [id], onDelete: SetNull)
  captions GeneratedCaption[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([visitId])
  @@map("gallery_images")
}

model GeneratedCaption {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  imageId   String   @map("image_id")
  content   String
  platform  String   @default("instagram")
  createdAt DateTime @default(now()) @map("created_at")

  user  User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  image GalleryImage @relation(fields: [imageId], references: [id], onDelete: Cascade)

  @@index([imageId])
  @@map("generated_captions")
}
